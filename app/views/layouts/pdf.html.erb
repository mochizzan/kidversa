<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Laporan Perkembangan Siswa</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      font-family: 'Times New Roman', serif;
      background: #fff;
      color: #333;
      -webkit-print-color-adjust: exact;
    }

    .page-container {
      width: 100%;
      height: 100%;
      position: relative;
      box-sizing: border-box;
      padding: 40px;
    }

    .certificate-border {
      border: 5px double #1a4373;
      padding: 20px;
      height: 950px;
      position: relative;
    }

    .text-center { text-align: center; }
    .text-right { text-align: right; }
    .text-bold { font-weight: bold; }
    .text-uppercase { text-transform: uppercase; }
    .mb-20 { margin-bottom: 20px; }
    .mt-20 { margin-top: 20px; }
    
    .clearfix:after {
      content: "";
      display: table;
      clear: both;
    }
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>