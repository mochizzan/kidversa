<div class="container py-4">

  <div class="mb-4">
    <a href="<%= admin_path %>" class="btn btn-white bg-white border shadow-sm rounded-pill px-4 py-2 text-decoration-none text-secondary d-inline-flex align-items-center transition-hover">
      <i class="bi bi-arrow-left me-2"></i> 
      <span class="fw-bold small">Kembali ke Dashboard</span>
    </a>
  </div>

  <div class="row align-items-center mb-4">
    <div class="col-md-6">
      <h2 class="fw-bold text-dark m-0">Input Nilai Anak</h2>
      <p class="text-muted small m-0">Kelola penilaian hasil belajar anak.</p>
    </div>
    
    <div class="col-md-6 mt-3 mt-md-0">
      <%= form_with url: data_nilai_path, method: :get,
          data: {
            controller: "autosubmit", 
            turbo_frame: "list-nilai",
            turbo_action: "advance"
            } do |f| %>
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0 ps-3 text-muted rounded-start-pill">
            <i class="bi bi-search"></i>
          </span>
          <%= f.search_field :search,
          class: "form-control border-start-0 ps-0 rounded-end-pill py-2 bg-white",
          placeholder: "Cari nama siswa atau NISN...",
          id: "search",
          value: params[:search],
          data: {action: "input->autosubmit#submit"}
          %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
      
      <turbo-frame id="list-nilai">
        <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="bg-light border-bottom">
            <tr>
              <th class="ps-4 py-3 text-secondary text-uppercase small" style="width: 5%;">No</th>
              <th class="py-3 text-secondary text-uppercase small" style="width: 45%;">Data Siswa</th> <th class="py-3 text-secondary text-uppercase small text-center">Status</th>
              <th class="pe-4 py-3 text-secondary text-uppercase small text-end">Aksi</th>
            </tr>
          </thead>

            <tbody>
            <% if @data_siswa.present? %>
              <%
              @data_siswa.each_with_index do |data, i|
              puts data.inspect

              status_penilaian = data.status_penilaians
              if status_penilaian.present?
                complete = true
              else
                complete = false
              end
              %>
                <%= render 'shared/list_data_penilaian', {data: data, i: i, complete: complete} %>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center py-5">
                  <div class="d-flex flex-column align-items-center justify-content-center py-4">
                    <div class="mb-3 text-secondary opacity-25">
                      <i class="bi bi-clipboard-x display-1"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Belum ada data penilaian</h5>
                    <p class="text-muted small mb-0">
                      Data siswa yang Anda cari tidak ditemukan atau belum dinilai.
                    </p>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>

        </table>
      </div>
      </turbo-frame>

      <div class="card-footer bg-white border-top-0 py-3 px-4 d-flex justify-content-between align-items-center">
        <span class="text-muted small">Menampilkan data siswa</span>
        <nav aria-label="Page navigation">
          <ul class="pagination pagination-sm mb-0">
            <li class="page-item disabled"><a class="page-link border-0 rounded-circle mx-1" href="#">&laquo;</a></li>
            <li class="page-item active"><a class="page-link border-0 rounded-circle mx-1" href="#">1</a></li>
            <li class="page-item"><a class="page-link border-0 rounded-circle mx-1" href="#">&raquo;</a></li>
          </ul>
        </nav>
      </div>

    </div>
  </div>
</div>

<%= render 'shared/modal_tambah_catatan' %>

<style>
  .transition-hover:hover {
    background-color: #f8f9fa !important;
    transform: translateX(-3px);
  }
</style>