<div class="container py-4">
  
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
    
    <div class="d-flex align-items-center">
      <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 me-3 shadow-sm" style="width: 60px; height: 60px; font-size: 1.5rem;">
        <i class="bi bi-person-fill"></i>
      </div>
      <div>
        <div class="d-flex align-items-center gap-2">
          <h4 class="fw-bold text-dark m-0">Halo, <%= @nama_guru %></h4> 
          
          <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill cursor-pointer px-3 py-2" 
                data-bs-toggle="modal" 
                data-bs-target="#modalTahunAjaran"
                title="Klik untuk ganti Tahun Ajaran">
            <i class="bi bi-calendar-check me-1"></i>
            <%= @tahun_ajaran_aktif ? @tahun_ajaran_aktif.nama : "Pilih TA" %>
          </span>
          </div>
        <p class="text-muted small m-0 mt-1">Selamat beraktivitas kembali, Pak/Bu.</p>
      </div>
    </div>

    <a href="<%= logout_path %>" class="btn btn-outline-danger rounded-pill px-4 py-2 fw-bold d-flex align-items-center justify-content-center transition-hover">
      <i class="bi bi-box-arrow-right me-2"></i> Keluar
    </a>
  </div>

  <div class="row g-4 mb-5">
    
    <div class="col-12 col-md-4">
      <div class="card h-100 border-0 shadow-sm rounded-4 hover-card position-relative overflow-hidden border-bottom border-4 border-primary">
        <div class="card-body p-4 text-center d-flex flex-column align-items-center justify-content-between">
          
          <div class="icon-circle bg-primary bg-opacity-10 text-primary mb-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
            <i class="bi bi-people-fill fs-4"></i>
          </div>
          
          <div class="my-3">
            <h2 class="display-5 fw-bold text-primary mb-0"><%= @total_siswa || 0 %></h2>
            <span class="text-muted small text-uppercase fw-bold ls-1">Anak Aktif</span>
          </div>
          
          <div class="w-100">
             <p class="text-muted small mb-3">Kelola profil & data anak.</p>
             <a href="<%= data_siswa_path %>" class="btn btn-primary rounded-pill px-4 fw-bold w-100 stretched-link">Kelola Siswa</a>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-4">
      <div class="card h-100 border-0 shadow-sm rounded-4 hover-card position-relative overflow-hidden border-bottom border-4 border-warning">
        <div class="card-body p-4 text-center d-flex flex-column align-items-center justify-content-between">
          
          <div class="icon-circle bg-warning bg-opacity-10 text-warning mb-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
            <i class="bi bi-collection-play-fill fs-4"></i>
          </div>
          
          <div class="my-3">
            <h2 class="display-5 fw-bold text-warning mb-0"><%= @total_pertanyaan || 0 %></h2>
            <span class="text-muted small text-uppercase fw-bold ls-1">Assesment Guru untuk Anak</span>
          </div>
          
          <div class="w-100">
            <p class="text-muted small mb-3">Atur indikator assesment.</p>
            <a href="<%= data_pertanyaan_path %>" class="btn btn-warning text-dark rounded-pill px-4 fw-bold w-100 stretched-link">Kelola Indikator</a>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-4">
      <div class="card h-100 border-0 shadow-sm rounded-4 hover-card position-relative overflow-hidden border-bottom border-4 border-success">
        <div class="card-body p-4 text-center d-flex flex-column align-items-center justify-content-between">
          
          <div class="icon-circle bg-success bg-opacity-10 text-success mb-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
            <i class="bi bi-bar-chart-fill fs-4"></i>
          </div>
          
          <div class="my-3 d-flex align-items-center justify-content-center" style="min-height: 60px;">
             <i class="bi bi-graph-up-arrow text-success opacity-50 display-6"></i>
          </div>
          
          <div class="w-100">
            <p class="text-muted small mb-3">Lihat & mulai assesment anak.</p>
            <a href="<%= data_nilai_path %>" class="btn btn-success rounded-pill px-4 fw-bold w-100 stretched-link">Data Assesment</a>
          </div>
        </div>
      </div>
    </div>

  </div>

  <div class="row">
  <div class="col-12">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
      
      <div class="card-header bg-white border-0 py-4 px-4 d-flex justify-content-between align-items-center">
        
        <div>
           <h5 class="fw-bold m-0 d-flex align-items-center">
              <span class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                <i class="bi bi-bar-chart-fill fs-5"></i>
              </span>
              Statistik Mingguan
           </h5>
           <p class="text-muted small ms-5 ps-2 mb-0">Progress assesment anak minggu ini</p>
        </div>
        
        <div class="text-end ps-3 border-start">
            <h2 class="fw-bold text-primary m-0 lh-1"><%= @total_dinilai_minggu_ini || 0 %></h2>
            <small class="text-secondary fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 1px;">Siswa Selesai</small>
        </div>

      </div>

      <div class="card-body p-4 pt-2">
        <div style="position: relative; height: 320px; width: 100%;">
          <canvas id="weeklyProgressChart"></canvas>
        </div>
      </div>
      
      </div>
  </div>
</div>

</div>

<%= render 'shared/modal_tahun_ajaran' %>

<style>
  .hover-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .hover-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
  }
  .ls-1 {
    letter-spacing: 1px;
  }
  .cursor-pointer {
    cursor: pointer;
  }
</style>

<script>
  document.addEventListener("turbo:load", function() { 
    const ctx = document.getElementById('weeklyProgressChart');

    if (ctx) {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['Senin', 'Selasa', 'Rabu', 'Kamis', 'Jum\'at', 'Sabtu', 'Minggu'],
          datasets: [{
            label: 'Jumlah Siswa',
            data: <%= @data_grafik.to_json.html_safe %>, 
            backgroundColor: 'rgba(54, 162, 235, 0.2)',
            borderColor: 'rgba(54, 162, 235, 1)',
            borderWidth: 1,
            borderRadius: 6,
            barThickness: 25,
            maxBarThickness: 40
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            },
            tooltip: {
               backgroundColor: '#333',
               titleFont: { size: 13 },
               bodyFont: { size: 14 },
               padding: 10,
               cornerRadius: 8,
               displayColors: false,
               callbacks: {
                   label: function(context) {
                       return context.parsed.y + ' Siswa';
                   }
               }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: {
                borderDash: [5, 5],
                color: '#f8f9fa'
              },
              ticks: {
                 stepSize: 1,
                 font: { size: 11 }
              }
            },
            x: {
              grid: {
                display: false
              },
              ticks: {
                 font: { size: 12 }
              }
            }
          }
        }
      });
    }
  });
</script>