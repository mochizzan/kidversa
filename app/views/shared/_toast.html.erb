<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1060;">
  
  <div id="liveToast" class="toast border-0 shadow-lg rounded-4 overflow-hidden" role="alert" aria-live="assertive" aria-atomic="true" style="min-width: 320px;">
    <div class="d-flex align-items-stretch">
      
      <div id="toastColorStrip" class="bg-success" style="width: 8px; flex-shrink: 0;"></div>
      
      <div class="toast-body p-3 d-flex align-items-center w-100">
        <div id="toastIconContainer" class="me-3 text-success">
          <i id="toastIcon" class="bi bi-check-circle-fill fs-3"></i>
        </div>
        
        <div>
          <h6 id="toastTitle" class="fw-bold text-dark mb-0">Berhasil!</h6>
          <p id="toastMessage" class="text-muted small mb-0" style="line-height: 1.2;">Data berhasil disimpan.</p>
        </div>

        <button type="button" class="btn-close ms-auto align-self-start" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>

    </div>
  </div>

</div>

<script>
function showNotification(tipe, judul, pesan) {
  const toastElement = document.getElementById('liveToast');
  const toastColorStrip = document.getElementById('toastColorStrip');
  const toastIconContainer = document.getElementById('toastIconContainer');
  const toastIcon = document.getElementById('toastIcon');
  const toastTitle = document.getElementById('toastTitle');
  const toastMessage = document.getElementById('toastMessage');

  toastColorStrip.classList.remove('bg-success', 'bg-danger');
  toastIconContainer.classList.remove('text-success', 'text-danger');
  toastIcon.classList.remove('bi-check-circle-fill', 'bi-x-circle-fill');

  if (tipe === 'success') {
    toastColorStrip.classList.add('bg-success');
    toastIconContainer.classList.add('text-success');
    toastIcon.classList.add('bi-check-circle-fill');
  } else {
    toastColorStrip.classList.add('bg-danger');
    toastIconContainer.classList.add('text-danger');
    toastIcon.classList.add('bi-x-circle-fill');
  }

  toastTitle.innerText = judul;
  toastMessage.innerText = pesan;

  const toast = new bootstrap.Toast(toastElement);
  toast.show();
}
</script>