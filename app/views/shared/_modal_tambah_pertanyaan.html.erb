<div class="modal fade" id="modalTambahPertanyaan" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered"> <div class="modal-content border-0 shadow rounded-4">
      
      <div class="modal-header bg-primary bg-opacity-10 border-bottom-0 py-3">
        <div class="d-flex align-items-center">
          <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
            <i class="bi bi-list-check fs-5"></i>
          </div>
          <div>
            <h5 class="modal-title fw-bold text-dark" id="modalLabel">Tambah Indikator</h5>
            <p class="mb-0 text-muted small">Buat parameter penilaian baru.</p>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <%= form_with url: tambah_data_pertanyaan_path, method: :post do |f| %>
        <div class="modal-body p-4">
          <div class="row g-3">

            <div class="col-12">
              <label for="inputIsi" class="form-label fw-bold text-secondary small text-uppercase">Isi Pertanyaan / Indikator</label>
              <%= f.text_area :isi, 
                  class: "form-control bg-light", 
                  id: "inputIsi", 
                  rows: 4, 
                  placeholder: "Contoh: Apakah siswa mampu mengenali angka 1-10?", 
                  required: true,
                  style: "resize: none;" 
              %>
            </div>

          </div>
        </div>

        <div class="modal-footer border-top-0 px-4 pb-4">
          <button type="button" class="btn btn-light rounded-pill px-4 fw-bold text-secondary" data-bs-dismiss="modal">
            Batal
          </button>
          
          <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Simpan
          </button>
        </div>
      <% end %>

    </div>
  </div>
</div>

