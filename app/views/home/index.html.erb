<div class="min-vh-100 d-flex align-items-center justify-content-center position-relative overflow-hidden bg-soft-gradient py-5">
  
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>

  <div class="container position-relative z-2">
    <div class="row align-items-center justify-content-center g-4 g-lg-5">
      
      <div class="col-lg-6 text-center text-lg-start">
        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-10 rounded-pill px-3 py-2 mb-3 fw-bold tracking-wide">
          👋 PORTAL WALI MURID
        </span>
        
        <h1 class="display-4 fs-1 fw-bolder text-dark mb-3" style="font-family: 'Plus Jakarta Sans', sans-serif;">
          Pantau Perkembangan <br> 
          <span class="text-primary position-relative">
            Anak Anda
            <svg class="position-absolute start-0 bottom-0 w-100 text-warning opacity-50" height="12" viewBox="0 0 100 12" preserveAspectRatio="none" style="z-index: -1;">
              <path d="M0,10 Q50,0 100,10" stroke="currentColor" stroke-width="8" fill="none" />
            </svg>
          </span> 
          Secara Real-time
        </h1>
        
        <p class="lead text-muted mb-4 pe-lg-5 fs-6">
          Akses mudah ke data penilaian dan capaian belajar anak. Masukkan data yang valid untuk memulai penelusuran.
        </p>

        <div class="d-inline-block text-start bg-white bg-opacity-75 backdrop-blur rounded-4 p-3 border shadow-sm mx-auto mx-lg-0">
          <div class="d-flex gap-3 align-items-center">
            <div class="icon-square bg-warning bg-opacity-10 text-warning rounded-3 p-2 flex-shrink-0">
              <i class="bi bi-info-circle-fill fs-4"></i>
            </div>
            <div>
              <small class="d-block fw-bold text-dark text-uppercase" style="font-size: 0.7rem;">Pusat Bantuan</small>
              <small class="text-muted lh-sm d-block" style="font-size: 0.8rem;">
                Nama tak ditemukan? Cek ejaan KK atau hubungi <span class="fw-bold text-dark text-nowrap">0812-XXXX-XXXX</span>
              </small>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-5 col-xl-4">
        <div class="card border-0 shadow-lg rounded-5 overflow-hidden glass-card mx-auto" style="max-width: 500px;">
          <div class="card-header border-0 bg-transparent pt-4 pb-2 text-center">
            <div class="mb-2">
              <div class="avatar-placeholder bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px;">
                <i class="bi bi-person-badge fs-3"></i>
              </div>
            </div>
            <h5 class="fw-bold text-dark">Cek Assessment Anak</h5>
          </div>

          <div class="card-body p-3 p-sm-4 pt-2">
            
            <form action="<%= cek_assesment_path %>" method="get">
              
              <div class="form-floating mb-3">
                <input type="text" class="form-control bg-light border-0 fw-bold text-dark" id="nisn" name="nisn" placeholder="Nomor NISN" required style="height: 55px;">
                <label for="nisn" class="text-secondary opacity-75">
                  <i class="bi bi-upc-scan me-1"></i> Nomor NISN
                </label>
              </div>

              <div class="form-floating mb-4">
                <input type="text" class="form-control bg-light border-0 fw-bold text-dark" id="institution" name="lembaga" placeholder="Nama Lembaga" required style="height: 55px;">
                <label for="institution" class="text-secondary opacity-75">
                  <i class="bi bi-building me-1"></i> Nama Lembaga
                </label>
              </div>

              <div class="d-grid">
                <button type="submit" class="btn btn-primary py-3 rounded-4 fw-bold shadow-lg btn-hover-scale d-flex align-items-center justify-content-center gap-2">
                  <span>Cek Sekarang</span>
                  <i class="bi bi-arrow-right"></i>
                </button>
              </div>

            </form>

            <div class="text-center mt-4">
              <small class="text-muted" style="font-size: 0.75rem;">
                &copy; <%= Date.today.year %> Kidversa by CV EduMed
              </small>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  body {
    font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .bg-soft-gradient { background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); }
  .glass-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.5);
  }
  .backdrop-blur { backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
  .form-control:focus { background-color: #fff !important; box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.15); }
  .btn-hover-scale { transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .btn-hover-scale:hover { transform: scale(1.02); }
  
  .blob { position: absolute; filter: blur(80px); z-index: 0; opacity: 0.6; animation: moveBlob 10s infinite alternate; }
  .blob-1 { top: -10%; left: -10%; width: 500px; height: 500px; background: #dbeafe; border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; }
  .blob-2 { bottom: -10%; right: -10%; width: 400px; height: 400px; background: #fef3c7; border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; animation-delay: -5s; }
  @keyframes moveBlob { 0% { transform: translate(0, 0) rotate(0deg); } 100% { transform: translate(50px, 50px) rotate(20deg); } }
  

  @media (max-width: 576px) {
    h1.display-4 { font-size: 2.5rem !important; }
    .blob { opacity: 0.4; width: 300px; height: 300px; }
  }
</style>