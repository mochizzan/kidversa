<div class="container py-5">
  
  <div class="mb-4">
      <a href="<%= root_path %>" class="btn btn-light bg-white border shadow-sm rounded-pill px-4 py-2 text-decoration-none text-secondary d-inline-flex align-items-center">
        <i class="bi bi-arrow-left me-2"></i> 
        <span class="fw-bold small text-uppercase">Kembali ke Pencarian</span>
      </a>
    </div>

  <div class="row g-4">
    
    <div class="col-lg-4">
      <div class="card card-profile shadow-sm rounded-4 h-100 overflow-hidden">
        <div class="card-body p-0">
          
          <div class="text-center p-4 pb-0">
            <div class="d-inline-block p-1 bg-white rounded-circle shadow-sm mb-3">
              <img src="<%= @profile_path.present? ? @profile_path : "https://ui-avatars.com/api/?name=#{@studentName}&background=random" %>" 
                   class="rounded-circle" 
                   alt="Foto Anak" 
                   style="width: 120px; height: 120px; object-fit: cover;">
            </div>
            <h4 class="fw-bold text-dark mb-1"><%= @studentName %></h4>
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill mt-2">
              KELOMPOK: <%= @kelompok_usia %> </span>
          </div>

          <div class="p-4">
            <h6 class="text-uppercase text-secondary x-small fw-bold mb-3 ls-1">Data Anak</h6>
            
            <ul class="list-unstyled d-grid gap-3 mb-4">
              <li class="d-flex justify-content-between">
                <span class="text-muted small">NISN</span>
                <span class="fw-bold text-dark small"><%= @nisn %></span>
              </li>
              <li class="d-flex justify-content-between">
                <span class="text-muted small">Tahun Ajaran</span>
                <span class="fw-bold text-dark small"><%= @tahun_ajaran.nama %></span>
              </li>
              <li class="d-flex justify-content-between">
                <span class="text-muted small">Tempat, Tgl Lahir</span>
                <span class="fw-bold text-dark small text-end"><%= @tempat_lahir %>, <%= @tanggal_lahir %></span>
              </li>
              <li class="d-flex justify-content-between">
                <span class="text-muted small">Usia Saat Ini</span>
                <span class="fw-bold text-dark small"><%= @usia %> Tahun</span>
              </li>
              <li class="d-flex justify-content-between align-items-center">
                <span class="text-muted small">Wali Kelas/Pembimbing</span>
                <span class="fw-bold text-primary small text-end"><%= @guru_pembimbing %></span>
              </li>
            </ul>

            <hr class="border-light my-4">

            <h6 class="text-uppercase text-secondary x-small fw-bold mb-3 ls-1">Data Orang Tua</h6>
            
            <div class="parent-info-box mb-3">
              <div class="d-flex align-items-center mb-2">
                <i class="bi bi-gender-male text-primary me-2"></i>
                <span class="fw-bold text-dark small">Ayah</span>
              </div>
              <div class="small text-dark mb-1"><%= @nama_ayah %></div>
              <div class="x-small text-muted"><i class="bi bi-briefcase me-1"></i> <%= @pekerjaan_ayah %></div>
            </div>

            <div class="parent-info-box">
              <div class="d-flex align-items-center mb-2">
                <i class="bi bi-gender-female text-danger me-2"></i>
                <span class="fw-bold text-dark small">Ibu</span>
              </div>
              <div class="small text-dark mb-1"><%= @nama_ibu %></div>
              <div class="x-small text-muted"><i class="bi bi-briefcase me-1"></i> <%= @pekerjaan_ibu %></div>
            </div>

          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      
      <div class="mb-4">
        <h3 class="fw-bold text-dark m-0">Laporan Perkembangan</h3>
        <p class="text-muted small mb-0">Rekapitulasi capaian pembelajaran anak.</p>
      </div>

      <div class="bg-light border rounded-3 p-3 mb-4">
          <h6 class="fw-bold text-secondary x-small text-uppercase mb-2">Keterangan Nilai:</h6>
          <div class="d-flex flex-wrap gap-3 gap-md-4">
              <div class="d-flex align-items-center">
                  <span class="badge badge-bb me-2">BB</span>
                  <span class="small text-dark">Belum Berkembang</span>
              </div>
              <div class="d-flex align-items-center">
                  <span class="badge badge-mb me-2">MB</span>
                  <span class="small text-dark">Mulai Berkembang</span>
              </div>
              <div class="d-flex align-items-center">
                  <span class="badge badge-bsh me-2">BSH</span>
                  <span class="small text-dark">Berkembang Sesuai Harapan</span>
              </div>
              <div class="d-flex align-items-center">
                  <span class="badge badge-bsb me-2">BSB</span>
                  <span class="small text-dark">Berkembang Sangat Baik</span>
              </div>
          </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 mb-4 bg-primary text-white position-relative overflow-hidden">
        <div class="card-body p-4 position-relative" style="z-index: 1;">
          <div class="d-flex align-items-start gap-3">
             <div class="bg-white bg-opacity-25 p-2 rounded-circle">
                 <i class="bi bi-chat-quote-fill text-white fs-4"></i>
             </div>
             <div>
                 <h6 class="fw-bold text-white mb-1">Catatan Guru Pembimbing</h6>
                 <p class="mb-0 text-white opacity-75 fw-light" style="font-size: 0.95rem; line-height: 1.6;">
                   "<%= @catatan || "Ananda menunjukkan perkembangan yang sangat positif dalam bersosialisasi." %>"
                 </p>
             </div>
          </div>
        </div>
        <i class="bi bi-stars position-absolute text-white opacity-10" style="bottom: -20px; right: -20px; font-size: 8rem;"></i>
      </div>

      <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
          <table class="table table-assessment align-middle mb-0">
            <thead class="bg-light border-bottom">
              <tr>
                <th class="py-3 ps-4 text-secondary text-uppercase x-small fw-bold" style="width: 70%;">Indikator Capaian</th>
                <th class="py-3 pe-4 text-secondary text-uppercase x-small fw-bold text-center" style="width: 30%;">Capaian</th>
              </tr>
            </thead>
            <tbody>
              <% @assessments.each do |assessment| %>
              <tr>
                <td class="ps-4 py-3">
                  <div class="d-flex flex-column">
                    <span class="fw-medium text-dark mb-1">
                      <%= assessment.pertanyaan.nama_pertanyaan %>
                    </span>
                    <span class="teacher-note">
                        <i class="bi bi-person-check-fill me-1 text-primary"></i> Penilai: <%= assessment.guru.nama %>
                    </span>
                  </div>
                </td>
                <td class="pe-4 text-center">
                    <span class="badge badge-<%= assessment.nilai.downcase %>" style="font-size: 0.85rem; padding: 6px 12px;"><%= assessment.nilai %></span>
                </td>
              </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="mt-4 text-end">
        <%= link_to request.params.merge(format: :pdf), class: "btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm hover-lift", target: "_blank" do %>
            <i class="bi bi-printer me-2"></i> Cetak Laporan
        <% end %>
      </div>

    </div>
  </div>
</div>

<style>
  .table-assessment td {
    vertical-align: middle;
  }

  .card-profile {
    background: linear-gradient(145deg, #ffffff, #f8f9fa);
    border: 1px solid rgba(0,0,0,0.05);
  }

  .parent-info-box {
    background-color: #fcfcfc;
    border: 1px dashed #dee2e6;
    border-radius: 12px;
    padding: 15px;
  }

  .score-badge {
    font-size: 0.75rem;
    letter-spacing: 0.5px;
    padding: 8px 16px;
    border-radius: 30px;
    width: 100%;
    display: block;
    text-align: center;
  }

  .badge-bb { background-color: #ffebee; color: #c62828; border: 1px solid #ffcdd2; }
  .badge-mb { background-color: #fff8e1; color: #f57f17; border: 1px solid #ffecb3; }
  .badge-bsh { background-color: #e8f5e9; color: #2e7d32; border: 1px solid #c8e6c9; }
  .badge-bsb { background-color: #e3f2fd; color: #1565c0; border: 1px solid #bbdefb; }

  .table-assessment td {
    vertical-align: middle;
  }

  .teacher-note {
    font-size: 0.85rem;
    color: #6c757d;
    display: flex;
    align-items: center;
    margin-top: 6px;
  }
</style>